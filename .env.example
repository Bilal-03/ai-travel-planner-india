# ==========================
# AI Travel Itinerary Planner — Environment Variables
# ==========================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it's in .gitignore already.

# --- LLM (required) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- Transport (optional — app works without these) ---
# Amadeus: https://developers.amadeus.com/
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# RailRadar: https://rapidapi.com/railradar/
RAILRADAR_API_KEY=your_railradar_api_key_here

# --- Weather (optional) ---
# OpenWeatherMap: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# --- Database (optional — falls back to in-memory) ---
# Supabase: https://supabase.com/
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# --- Cache (optional — falls back to in-memory) ---
# Upstash Redis: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# --- App ---
# Frontend URL (update to your Vercel URL after deployment)
FRONTEND_URL=http://localhost:3000
BACKEND_PORT=8000
